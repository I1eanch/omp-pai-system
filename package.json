{
  "name": "omp-pai-system",
  "version": "0.1.0",
  "description": "Portable PAI, Algorithm, TELOS, and MEMORY runtime for Oh My Pi",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": ["pi-package", "omp", "pai", "algorithm", "telos", "memory"],
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "files": [
    "src/",
    "contracts/",
    "templates/",
    "privacy/",
    "README.md",
    "CHANGELOG.md",
    "docs/",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json",
    "test:runtime": "bun test tests/runtime",
    "test:lifecycle": "bun test tests/lifecycle",
    "smoke:install": "bun scripts/lifecycle-smoke.ts",
    "build:staging": "bun scripts/build-staging.ts",
    "audit:privacy": "bun scripts/privacy-audit.ts",
    "release:pack": "bun scripts/release-pack.ts"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "^16.4.8"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "tar-stream": "^3.2.0"
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "^16.5.0",
    "@types/bun": "^1.3.14",
    "@types/tar-stream": "^3.1.4",
    "typescript": "^7.0.2"
  }
}
