{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/omp-pai-system/work-registry.schema.json",
  "title": "PAI work registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sessions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sessions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["prd", "phase", "updated"],
        "properties": {
          "prd": { "type": "string" },
          "phase": { "type": "string" },
          "updated": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
